# MicroClaw configuration

# Channel settings (set `enabled: false` to keep credentials without activating the channel)
# setup wizard default: web when no channels are selected
channels:
  web:
    enabled: true
  discord:
    enabled: true
    accounts:
      microclaw:
        bot_token: "${DISCORD_BOT_TOKEN}"
        allowed_channels: [1505384147089096776]
        no_mention: true               # sole bot in this channel, no @-mention needed
        provider_preset: "lmstudio"
        enabled: true
      clawde:
        bot_token: "${DISCORD_BOT_TOKEN_ANTHROPIC}"   # env var still named _ANTHROPIC; bot renamed clawde, now routes to MiniMax
        allowed_channels: [1505383554597523708]
        no_mention: true
        provider_preset: "minimax"
        enabled: true
    default_account: clawde

subagents:
  enabled: false
  max_concurrent: 0
  max_active_per_chat: 0
  run_timeout_secs: 900
  announce_to_chat: true
  max_spawn_depth: 1
  max_children_per_run: 5
  thread_bound_routing_enabled: true
  announce_relay_interval_secs: 15
  max_tokens_per_run: 400000
  orchestrate_max_workers: 5

# LLM provider (anthropic, openai-codex, ollama, openai, openrouter, deepseek, synthetic, chutes, google, etc.)
llm_provider: "anthropic"
# API key for LLM provider
api_key: "${ANTHROPIC_API_TOKEN}"
# Model name (leave empty for provider default)
model: "claude-sonnet-4-5-20250929"
# Optional reusable provider profiles for per-bot/channel selection
# provider_presets:
#   provider1:
#     provider: "openai"
#     api_key: "sk-..."
#     llm_base_url: "https://example.com/v1"
#     llm_user_agent: "microclaw/1.0"
#     default_model: "gpt-5.2"
#     show_thinking: false
#   deepseek-hk:
#     provider: "deepseek"
#     api_key: "sk-..."
provider_presets:
  lmstudio:
    provider: "anthropic"
    api_key: "lm-studio"                              # ignored by LMStudio, field required
    llm_base_url: "http://host.docker.internal:1234"  # Anthropic /v1/messages via neptune lmstudio-proxy; microclaw appends the path
    default_model: "qwen3.5-9b-mtp"
  minimax:
    provider: "anthropic"
    api_key: "${MINIMAX_API_KEY}"
    llm_base_url: "https://api.minimax.io/anthropic"
    default_model: "MiniMax-M2.7"
# Show model thinking/reasoning text when available
show_thinking: false
# OpenAI-compatible request body overrides (optional)
# Use null to unset a default key for selected provider/model.
# openai_compat_body_overrides: { temperature: 0.2 }
# openai_compat_body_overrides_by_provider:
#   deepseek: { top_p: null, reasoning_effort: "high" }
# openai_compat_body_overrides_by_model:
#   gpt-5.2: { response_format: { type: "json_object" } }

data_dir: "/home/microclaw/.microclaw"
working_dir: "/home/microclaw/.microclaw/working_dir"
# Optional timezone override (IANA), e.g. Asia/Shanghai. Default: system timezone.
override_timezone: "America/Denver"
high_risk_tool_user_confirmation_required: true
# Optional container sandbox for bash tool execution
sandbox:
  mode: "all"
  backend: "auto"
  security_profile: "hardened"  # --cap-drop ALL --security-opt no-new-privileges
  image: "ubuntu:26.04"
  container_prefix: "microclaw-sandbox"
  no_network: true
  require_runtime: true

# Memory reflector: periodically extracts structured memories from conversations
reflector_enabled: false
reflector_interval_mins: 15
memory_token_budget: 1500

# Optional SOUL files directory (defaults to <data_dir>/souls)
souls_dir: "/home/jess/.microclaw/souls"
